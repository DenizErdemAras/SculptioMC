{
  "name": "gpu-mc",
  "version": "0.1.0",
  "description": "WebGPU-accelerated marching cubes with zero-copy Three.js integration",
  "type": "module",
  "main": "./dist/gpu-mc.js",
  "module": "./dist/gpu-mc.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/gpu-mc.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.165.0"
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "@webgpu/types": "^0.1.69",
    "three": "^0.180.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  }
}
